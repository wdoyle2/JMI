APP_NAME="Wind4Life"
APP_ENV=testing
APP_KEY=base64:ZNWPnLH8dc4WeF1XT7kYxqTLe6I4dXGmM8dTctBF/OM=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Tests run against a dedicated, empty MySQL database (created by
# docker/mysql/create-testing-database.sh on first container start) and use
# DatabaseTransactions (tests/TestCase.php) to roll back between tests — so
# local dev data in `wind4life` is never touched.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=wind4life_testing
DB_USERNAME=sail
DB_PASSWORD=password

BCRYPT_ROUNDS=4

CACHE_STORE=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
MAIL_MAILER=array

REDIS_HOST=redis
REDIS_PORT=6379
